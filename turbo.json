{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["prettier"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "deploy": {
      "dependsOn": ["lint", "build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "prettier": {},
    "prettier:fix": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
