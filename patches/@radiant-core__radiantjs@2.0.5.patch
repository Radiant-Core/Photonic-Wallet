diff --git a/lib/hdprivatekey.js b/lib/hdprivatekey.js
index 0cc903cf5086d6e2e978032ee2884d0f384bf319..7eca345e3d1e8f93a7116bdd233dd9a0a44467b9 100644
--- a/lib/hdprivatekey.js
+++ b/lib/hdprivatekey.js
@@ -653,6 +653,12 @@ HDPrivateKey.PrivateKeyEnd = HDPrivateKey.PrivateKeyStart + HDPrivateKey.Private
 HDPrivateKey.ChecksumStart = HDPrivateKey.PrivateKeyEnd
 HDPrivateKey.ChecksumEnd = HDPrivateKey.ChecksumStart + HDPrivateKey.CheckSumSize
 
-assert(HDPrivateKey.ChecksumEnd === HDPrivateKey.SerializedByteSize)
+// Self-contained invariant (was `assert(...)`): the module-scope `assert` import
+// can be undefined at this point when a bundler emits radiantjs's modules before
+// the `assert` polyfill — which white-screened consumers that code-split radiantjs
+// (e.g. Photonic's /predict chunk). A plain throw has no load-order dependency.
+if (HDPrivateKey.ChecksumEnd !== HDPrivateKey.SerializedByteSize) {
+  throw new Error('radiantjs: HDPrivateKey serialized byte-layout invariant violated')
+}
 
 module.exports = HDPrivateKey
diff --git a/lib/hdpublickey.js b/lib/hdpublickey.js
index 2dd5223d81dbe5dcb110ffe3943771f0f4feaec6..4743886d34e2a916ce901954d3b18f461fd1bc1e 100644
--- a/lib/hdpublickey.js
+++ b/lib/hdpublickey.js
@@ -503,7 +503,13 @@ HDPublicKey.PublicKeyEnd = HDPublicKey.PublicKeyStart + HDPublicKey.PublicKeySiz
 HDPublicKey.ChecksumStart = HDPublicKey.PublicKeyEnd
 HDPublicKey.ChecksumEnd = HDPublicKey.ChecksumStart + HDPublicKey.CheckSumSize
 
-assert(HDPublicKey.PublicKeyEnd === HDPublicKey.DataSize)
-assert(HDPublicKey.ChecksumEnd === HDPublicKey.SerializedByteSize)
+// Self-contained invariants (were `assert(...)`): the module-scope `assert` import
+// can be undefined here under some bundler emit orders — see hdprivatekey.js note.
+if (HDPublicKey.PublicKeyEnd !== HDPublicKey.DataSize) {
+  throw new Error('radiantjs: HDPublicKey data byte-layout invariant violated')
+}
+if (HDPublicKey.ChecksumEnd !== HDPublicKey.SerializedByteSize) {
+  throw new Error('radiantjs: HDPublicKey serialized byte-layout invariant violated')
+}
 
 module.exports = HDPublicKey
